# Copy to .env and fill in. Used by compose.yaml (production) at deploy time.
# The zero-LLM smoke (compose.smoke.yaml) needs NO secrets.

# ── OpenRouter (required for op:"qualify", the LLM path) ──────────────────────
# Snoopy reads this env directly (its keytar/OS-keyring path is unused in the
# container; it falls back to this variable). Get a key at openrouter.ai.
TELEPAT_OPENROUTER_KEY=

# ── Model settings (seeded into Snoopy's SQLite by the wrapper at startup) ────
# Snoopy has NO native env override for these; the wrapper applies them via the
# MCP snoopy_settings_set tool on boot.
SNOOPY_MODEL=deepseek/deepseek-v4-flash
SNOOPY_TEMPERATURE=0.3
SNOOPY_MAX_TOKENS=800
SNOOPY_TOP_P=1

# ── Optional default monitoring job (seeded only if no jobs exist yet) ────────
# SNOOPY_DEFAULT_JOB_NAME=default snoopy watch
# SNOOPY_DEFAULT_SUBREDDITS=startups,SaaS
# SNOOPY_DEFAULT_PROMPT=People asking for recommendations for a tool like ours.

# ── Reddit OAuth (OPTIONAL — for real leads where Reddit blocks this IP) ──────
# Snoopy uses public Reddit JSON by default, but Reddit returns HTTP 403 to many
# datacenter IPs unauthenticated. To get real qualified leads, create a Reddit
# "script" app (https://www.reddit.com/prefs/apps) and set these. client_id +
# app_name are seeded into Snoopy's settings DB at startup; the secret is read by
# Snoopy from SNOOPY_REDDIT_CLIENT_SECRET. Leave blank to stay unauthenticated.
# SNOOPY_REDDIT_CLIENT_ID=
# SNOOPY_REDDIT_APP_NAME=snoopy-pilot/0.1 (by /u/yourname)
# SNOOPY_REDDIT_CLIENT_SECRET=

# ── Pilot overlay endpoints ───────────────────────────────────────────────────
# Where the provider daemon registers so callers can reach the node. Defaults to
# the real Pilot network. Point these at a self-hosted rendezvous for a private
# deployment. Confirm the current Pilot registry/beacon with the Pilot team.
PILOT_REGISTRY=34.71.57.205:9000
PILOT_BEACON=34.71.57.205:9001

# ── Optional ──────────────────────────────────────────────────────────────────
# PILOT_HOSTNAME=snoopy-provider
# LOG_LEVEL=info

# Reddit needs NO OAuth — Snoopy uses public JSON endpoints. No Reddit creds here.
